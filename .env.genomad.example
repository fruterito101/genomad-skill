# Genomad Skill Configuration
# Copy to .env.genomad and fill in your values

# Network: testnet or mainnet
GENOMAD_NETWORK=testnet

# Your agent's token ID (from activation)
GENOMAD_TOKEN_ID=

# Your wallet address (for encryption/decryption)
GENOMAD_OWNER_ADDRESS=

# Agent private key (ONLY for write operations - KEEP SECRET)
# Remove this line if you only need read operations
GENOMAD_AGENT_PRIVATE_KEY=
